# Window padding
window-padding-x = 12
window-padding-y = 12

gtk-adwaita = true

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = block
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style

# Pywal Color Scheme - Generated automatically
background = #15202a
foreground = #c1cafc

# Selection colors
selection-background = #384f98
selection-foreground = #15202a

# Cursor colors
cursor-color = #c1cafc
cursor-text = #15202a

# Normal colors (0-7)
palette = 0=#15202a
palette = 1=#324685
palette = 2=#384f98
palette = 3=#37509a
palette = 4=#386684
palette = 5=#4c63d7
palette = 6=#4a60d7
palette = 7=#c1cafc

# Bright colors (8-15)
palette = 8=#294083
palette = 9=#324685
palette = 10=#384f98
palette = 11=#37509a
palette = 12=#386684
palette = 13=#4c63d7
palette = 14=#4a60d7
palette = 15=#c1cafc

confirm-close-surface = false
background-opacity = 0.88 
background-blur = true
