# Window padding
window-padding-x = 12
window-padding-y = 12

gtk-adwaita = true

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = block
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style

# Pywal Color Scheme - Generated automatically
background = #121217
foreground = #dfcdae

# Selection colors
selection-background = #292b3d
selection-foreground = #121217

# Cursor colors
cursor-color = #dfcdae
cursor-text = #121217

# Normal colors (0-7)
palette = 0=#121217
palette = 1=#241c24
palette = 2=#292b3d
palette = 3=#3e405c
palette = 4=#444c6a
palette = 5=#695e8a
palette = 6=#a480c2
palette = 7=#dfcdae

# Bright colors (8-15)
palette = 8=#59595c
palette = 9=#241c24
palette = 10=#292b3d
palette = 11=#3e405c
palette = 12=#444c6a
palette = 13=#695e8a
palette = 14=#a480c2
palette = 15=#dfcdae

confirm-close-surface = false
background-opacity = 0.88 
background-blur = true
