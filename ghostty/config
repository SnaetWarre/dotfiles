# Window padding
window-padding-x = 12
window-padding-y = 12

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = block
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style

# Pywal Color Scheme - Generated automatically
background = #00062d
foreground = #e3d3f1

# Selection colors
selection-background = #a2486a
selection-foreground = #00062d

# Cursor colors
cursor-color = #e3d3f1
cursor-text = #00062d

# Normal colors (0-7)
palette = 0=#00062d
palette = 1=#764162
palette = 2=#a2486a
palette = 3=#655bb2
palette = 4=#3378d1
palette = 5=#d56bab
palette = 6=#9973bb
palette = 7=#e3d3f1

# Bright colors (8-15)
palette = 8=#633c55
palette = 9=#764162
palette = 10=#a2486a
palette = 11=#655bb2
palette = 12=#3378d1
palette = 13=#d56bab
palette = 14=#9973bb
palette = 15=#e3d3f1

confirm-close-surface = false
background-opacity = 0.88 
background-blur = true
