# Window padding
window-padding-x = 12
window-padding-y = 12

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = block
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style

# Pywal Color Scheme - Generated automatically
background = #000000
foreground = #9d9d9d

# Selection colors
selection-background = #2d2d2d
selection-foreground = #000000

# Cursor colors
cursor-color = #9d9d9d
cursor-text = #000000

# Normal colors (0-7)
palette = 0=#000000
palette = 1=#000000
palette = 2=#2d2d2d
palette = 3=#242424
palette = 4=#4b4b4b
palette = 5=#3d3d3d
palette = 6=#5f5f5f
palette = 7=#9d9d9d

# Bright colors (8-15)
palette = 8=#4c4c4c
palette = 9=#000000
palette = 10=#2d2d2d
palette = 11=#242424
palette = 12=#4b4b4b
palette = 13=#3d3d3d
palette = 14=#5f5f5f
palette = 15=#9d9d9d

confirm-close-surface = false
background-opacity = 0.88 
background-blur = true
