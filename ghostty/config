# Window padding
window-padding-x = 7
window-padding-y = 7

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = bar
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style
# cursor-style-blink = true  # Uncomment if you want blinking cursor

# Pywal Color Scheme - Generated automatically
background = #253538
foreground = #dfe4e8

# Selection colors
selection-background = #797c6e
selection-foreground = #253538

# Cursor colors
cursor-color = #dfe4e8
cursor-text = #253538

# Normal colors (0-7)
palette = 0=#253538
palette = 1=#777768
palette = 2=#797c6e
palette = 3=#748383
palette = 4=#a68558
palette = 5=#90a6a3
palette = 6=#909ca7
palette = 7=#dfe4e8

# Bright colors (8-15)
palette = 8=#546d78
palette = 9=#777768
palette = 10=#797c6e
palette = 11=#748383
palette = 12=#a68558
palette = 13=#90a6a3
palette = 14=#909ca7
palette = 15=#dfe4e8


background-opacity = 0.7 
background-blur = true
