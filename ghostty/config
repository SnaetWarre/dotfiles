# Window padding
window-padding-x = 12
window-padding-y = 12

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = block
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style

# Pywal Color Scheme - Generated automatically
background = #152023
foreground = #ede9d9

# Selection colors
selection-background = #525c50
selection-foreground = #152023

# Cursor colors
cursor-color = #ede9d9
cursor-text = #152023

# Normal colors (0-7)
palette = 0=#152023
palette = 1=#244c7c
palette = 2=#525c50
palette = 3=#645c4e
palette = 4=#3d80bd
palette = 5=#418dd4
palette = 6=#9c7cb4
palette = 7=#ede9d9

# Bright colors (8-15)
palette = 8=#5b6265
palette = 9=#244c7c
palette = 10=#525c50
palette = 11=#645c4e
palette = 12=#3d80bd
palette = 13=#418dd4
palette = 14=#9c7cb4
palette = 15=#ede9d9

confirm-close-surface = false
background-opacity = 0.88 
background-blur = true
