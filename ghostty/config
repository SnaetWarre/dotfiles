# Window padding
window-padding-x = 12
window-padding-y = 12

gtk-adwaita = true

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = block
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style

# Pywal Color Scheme - Generated automatically
background = #151719
foreground = #d4d5d6

# Selection colors
selection-background = #63636e
selection-foreground = #151719

# Cursor colors
cursor-color = #d4d5d6
cursor-text = #151719

# Normal colors (0-7)
palette = 0=#151719
palette = 1=#59595b
palette = 2=#63636e
palette = 3=#626d6d
palette = 4=#6d6f71
palette = 5=#858789
palette = 6=#797b7d
palette = 7=#d4d5d6

# Bright colors (8-15)
palette = 8=#3b3b46
palette = 9=#59595b
palette = 10=#63636e
palette = 11=#626d6d
palette = 12=#6d6f71
palette = 13=#858789
palette = 14=#797b7d
palette = 15=#d4d5d6

confirm-close-surface = false
background-opacity = 0.88 
background-blur = true
