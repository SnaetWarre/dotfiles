# Window padding
window-padding-x = 7
window-padding-y = 7

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = bar
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style
# cursor-style-blink = true  # Uncomment if you want blinking cursor

# Pywal Color Scheme - Generated automatically
background = #0b0e0d
foreground = #f4f5f5

# Selection colors
selection-background = #958a95
selection-foreground = #0b0e0d

# Cursor colors
cursor-color = #f4f5f5
cursor-text = #0b0e0d

# Normal colors (0-7)
palette = 0=#0b0e0d
palette = 1=#858789
palette = 2=#958a95
palette = 3=#919395
palette = 4=#a59aa5
palette = 5=#c7c7c8
palette = 6=#bfc1c2
palette = 7=#f4f5f5

# Bright colors (8-15)
palette = 8=#676a6c
palette = 9=#858789
palette = 10=#958a95
palette = 11=#919395
palette = 12=#a59aa5
palette = 13=#c7c7c8
palette = 14=#bfc1c2
palette = 15=#f4f5f5


background-opacity = 0.7 
background-blur = true
