# Window padding
window-padding-x = 12
window-padding-y = 12

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = block
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style

# Pywal Color Scheme - Generated automatically
background = #0d1216
foreground = #bdc1c9

# Selection colors
selection-background = #243434
selection-foreground = #0d1216

# Cursor colors
cursor-color = #bdc1c9
cursor-text = #0d1216

# Normal colors (0-7)
palette = 0=#0d1216
palette = 1=#1c2c2c
palette = 2=#243434
palette = 3=#2c3c3c
palette = 4=#3c4d5c
palette = 5=#546c7c
palette = 6=#5d6c7c
palette = 7=#bdc1c9

# Bright colors (8-15)
palette = 8=#55595b
palette = 9=#1c2c2c
palette = 10=#243434
palette = 11=#2c3c3c
palette = 12=#3c4d5c
palette = 13=#546c7c
palette = 14=#5d6c7c
palette = 15=#bdc1c9

confirm-close-surface = false
background-opacity = 0.88 
background-blur = true
