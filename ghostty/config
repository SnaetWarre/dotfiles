# Window padding
window-padding-x = 12
window-padding-y = 12

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = block
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style

# Pywal Color Scheme - Generated automatically
background = #2c3a44
foreground = #dce2de

# Selection colors
selection-background = #697c7c
selection-foreground = #2c3a44

# Cursor colors
cursor-color = #dce2de
cursor-text = #2c3a44

# Normal colors (0-7)
palette = 0=#2c3a44
palette = 1=#60776c
palette = 2=#697c7c
palette = 3=#70807a
palette = 4=#7c8a83
palette = 5=#94a399
palette = 6=#8a998f
palette = 7=#dce2de

# Bright colors (8-15)
palette = 8=#556868
palette = 9=#60776c
palette = 10=#697c7c
palette = 11=#70807a
palette = 12=#7c8a83
palette = 13=#94a399
palette = 14=#8a998f
palette = 15=#dce2de

confirm-close-surface = false
background-opacity = 0.88 
background-blur = true
