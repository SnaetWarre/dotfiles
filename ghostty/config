# Window padding
window-padding-x = 12
window-padding-y = 12

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = block
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style

# Pywal Color Scheme - Generated automatically
background = #131428
foreground = #cfd8d6

# Selection colors
selection-background = #595d6b
selection-foreground = #131428

# Cursor colors
cursor-color = #cfd8d6
cursor-text = #131428

# Normal colors (0-7)
palette = 0=#131428
palette = 1=#474d5e
palette = 2=#595d6b
palette = 3=#635c6b
palette = 4=#7d5a73
palette = 5=#7e818a
palette = 6=#6d827e
palette = 7=#cfd8d6

# Bright colors (8-15)
palette = 8=#433859
palette = 9=#474d5e
palette = 10=#595d6b
palette = 11=#635c6b
palette = 12=#7d5a73
palette = 13=#7e818a
palette = 14=#6d827e
palette = 15=#cfd8d6

confirm-close-surface = false
background-opacity = 0.88 
background-blur = true
