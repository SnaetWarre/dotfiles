# Window padding
window-padding-x = 12
window-padding-y = 12
window-padding-color = extend

gtk-adwaita = true

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = block
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style

# Pywal Color Scheme - Generated automatically
background = #1c1b18
foreground = #f8e2d0

# Selection colors
selection-background = #44a9d6
selection-foreground = #1c1b18

# Cursor colors
cursor-color = #f8e2d0
cursor-text = #1c1b18

# Normal colors (0-7)
palette = 0=#1c1b18
palette = 1=#2494da
palette = 2=#44a9d6
palette = 3=#47a9d6
palette = 4=#4ca4e6
palette = 5=#6fbbf0
palette = 6=#cc986b
palette = 7=#f8e2d0

# Bright colors (8-15)
palette = 8=#69422c
palette = 9=#2494da
palette = 10=#44a9d6
palette = 11=#47a9d6
palette = 12=#4ca4e6
palette = 13=#6fbbf0
palette = 14=#cc986b
palette = 15=#f8e2d0

confirm-close-surface = false
background-opacity = 0.88 
background-blur = true
