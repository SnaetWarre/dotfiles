# Window padding
window-padding-x = 12
window-padding-y = 12
window-padding-color = extend

# Font configuration
font-size = 18.0

# Font family - Ghostty uses a single font-family setting
# and automatically finds bold, italic, and bold-italic variants
font-family = JetBrains Mono

# You can explicitly set font families for different styles if needed:
font-family-bold = JetBrains Mono
font-family-italic = JetBrains Mono
font-family-bold-italic = JetBrains Mono

# Cursor configuration
cursor-style = block
# Note: Ghostty doesn't have separate vi_mode_style - it uses the same cursor style

# Pywal Color Scheme - Generated automatically
background = #1a1418
foreground = #efe2c5

# Selection colors
selection-background = #7c3c24
selection-foreground = #1a1418

# Cursor colors
cursor-color = #efe2c5
cursor-text = #1a1418

# Normal colors (0-7)
palette = 0=#1a1418
palette = 1=#332e39
palette = 2=#7c3c24
palette = 3=#6b545b
palette = 4=#b15c41
palette = 5=#c87d46
palette = 6=#c5aa93
palette = 7=#efe2c5

# Bright colors (8-15)
palette = 8=#5e5a5d
palette = 9=#332e39
palette = 10=#7c3c24
palette = 11=#6b545b
palette = 12=#b15c41
palette = 13=#c87d46
palette = 14=#c5aa93
palette = 15=#efe2c5

confirm-close-surface = false
background-opacity = 0.88 
background-blur = true
